{
  "name": "history-clipboard",
  "version": "1.0.0",
  "description": "历史粘贴板 — 自动记录剪贴板文字和图片的 Windows 桌面工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "chcp 65001 > nul && node_modules\\electron\\dist\\electron.exe . --disable-gpu --disable-software-rasterizer",
    "start:dev": "set ELECTRON_RUN_AS_NODE= && node_modules\\electron\\dist\\electron.exe . --disable-gpu --disable-software-rasterizer --dev",
    "test": "node --test test\\*.test.js",
    "build": "electron-builder",
    "gen-icon": "node assets/generate-icon.js"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
